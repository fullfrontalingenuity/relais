#!/usr/bin/env bash
set -euo pipefail

if command -v devbox >/dev/null 2>&1; then
  exec devbox run setup "$@"
fi

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

echo "→ Relais setup"
echo "  Tip: install devbox for a reproducible environment — https://www.jetify.com/devbox"
echo "  Project: $ROOT"

if ! command -v ruby >/dev/null 2>&1; then
  echo "→ Ruby not found. Install it, then re-run ./bin/setup:"
  echo ""
  echo "    sudo apt-get update"
  echo "    sudo apt-get install -y ruby-full build-essential zlib1g-dev"
  echo ""
  exit 1
fi

if ! command -v bundle >/dev/null 2>&1; then
  echo "→ Installing Bundler..."
  gem install bundler --no-document --user-install
  export PATH="${HOME}/.local/share/gem/ruby/$(ruby -e 'print RUBY_VERSION')/bin:${PATH}"
fi

echo "→ Ruby: $(ruby --version)"
echo "→ Bundler: $(bundle --version)"

bundle config set --local path 'vendor/bundle'
bundle install

echo ""
echo "✓ Setup complete. Run: ./bin/serve"